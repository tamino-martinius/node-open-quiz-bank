{
  "name": "open-quiz-bank",
  "version": "1.0.0",
  "description": "Open, seedable bilingual (de/en) quiz question bank with a small query API. Code MIT, questions CC0.",
  "author": "Tamino Martinius <io@tamino.dev>",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./esm/index.d.ts",
        "default": "./esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./en": {
      "import": {
        "types": "./esm/en.d.ts",
        "default": "./esm/en.js"
      },
      "require": {
        "types": "./dist/en.d.ts",
        "default": "./dist/en.js"
      }
    },
    "./de": {
      "import": {
        "types": "./esm/de.d.ts",
        "default": "./esm/de.js"
      },
      "require": {
        "types": "./dist/de.d.ts",
        "default": "./dist/de.js"
      }
    }
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tamino-martinius/node-open-quiz-bank.git"
  },
  "keywords": [
    "quiz",
    "trivia",
    "questions",
    "bank",
    "quizzes",
    "german",
    "english",
    "cc0",
    "seeded",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gen": "node scripts/build-manifest.mjs",
    "prebuild": "npm run gen",
    "compile": "rm -rf dist esm && npm run gen && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json --noCheck && node .github/scripts/write-build-markers.mjs",
    "lint": "biome check .",
    "format": "biome check --write .",
    "pretest": "npm run lint",
    "test": "vitest run",
    "coverage": "rm -rf coverage && vitest run --coverage",
    "test:scripts": "node --test .github/scripts/__tests__/*.mjs",
    "ci": "npm run coverage",
    "watch": "tsc -w -p tsconfig.json",
    "preversion": "npm run compile && git add ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
